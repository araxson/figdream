#!/bin/bash

# Claude Code Hook: Runs before each user prompt submission
# This hook generates the project tree and prepares context for Claude

# Always generate fresh project tree (whether new or continuing conversation)
echo "📊 Generating fresh project tree for Claude..."

# Generate the project tree
python3 generate_project_tree.py 2>/dev/null || {
    echo "⚠️ Could not generate project tree. Python script may be missing."
}

# Check if PROJECT_TREE.md exists and instruct Claude to read it
if [ -f "PROJECT_TREE.md" ]; then
    echo ""
    echo "📋 MANDATORY ACTION FOR CLAUDE:"
    echo "   1. Read PROJECT_TREE.md to get the latest project statistics"
    echo "   2. Check for any structural changes since last message"
    echo ""
    echo "   The file has been freshly generated and contains:"
    echo "   • Updated file and line counts"
    echo "   • Current file distribution"
    echo "   • Latest project structure"
    echo ""
    echo "⚠️  CLAUDE: You MUST read PROJECT_TREE.md with EVERY response to stay current."
    echo ""
fi

# Always allow the prompt to continue
exit 0