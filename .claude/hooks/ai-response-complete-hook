#!/bin/bash

# 🎯 Claude Code Hook: POST-RESPONSE VALIDATOR
# Runs after Claude completes a response
# Validates changes and suggests next steps

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}🔍 POST-RESPONSE VALIDATION${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Check if any files were modified in the last minute
MODIFIED_FILES=$(find src -type f \( -name "*.ts" -o -name "*.tsx" \) -mmin -1 2>/dev/null | wc -l || echo "0")

if [ "$MODIFIED_FILES" -gt 0 ]; then
    echo -e "${BLUE}📝 Files modified: $MODIFIED_FILES${NC}"
    echo ""
    
    # Run quick validation
    echo -e "${YELLOW}⏳ Running validation checks...${NC}"
    
    # Quick ESLint check (with timeout)
    ESLINT_RESULT=$(timeout 5 npm run lint 2>&1 | tail -1 || echo "Timeout")
    
    if echo "$ESLINT_RESULT" | grep -q "0 problems"; then
        echo -e "${GREEN}✅ ESLint: CLEAN - Zero errors achieved!${NC}"
    elif echo "$ESLINT_RESULT" | grep -q "problems"; then
        ERRORS=$(echo "$ESLINT_RESULT" | grep -oE '[0-9]+ problems' || echo "unknown problems")
        echo -e "${YELLOW}⚠️  ESLint: $ERRORS remaining${NC}"
        echo -e "${YELLOW}   Suggested: Run 'npm run lint' for details${NC}"
    fi
    
    # Check TypeScript (quick)
    TS_CHECK=$(timeout 5 npm run typecheck 2>&1 | grep -c "error TS" || echo "0")
    if [ "$TS_CHECK" = "0" ]; then
        echo -e "${GREEN}✅ TypeScript: No compilation errors detected${NC}"
    else
        echo -e "${YELLOW}⚠️  TypeScript: Potential errors detected${NC}"
        echo -e "${YELLOW}   Suggested: Run 'npm run typecheck' for details${NC}"
    fi
else
    echo -e "${BLUE}ℹ️  No files were modified in this response${NC}"
fi

# Check git status for uncommitted changes
UNCOMMITTED=$(git status --porcelain 2>/dev/null | wc -l || echo "0")
if [ "$UNCOMMITTED" -gt 0 ]; then
    echo ""
    echo -e "${MAGENTA}📦 Git Status: $UNCOMMITTED uncommitted changes${NC}"
    echo -e "${MAGENTA}   Consider: Review changes and commit when ready${NC}"
fi

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Suggest next steps based on validation results
if echo "$ESLINT_RESULT" | grep -q "0 problems"; then
    echo -e "${GREEN}🎉 EXCELLENT! Codebase is clean!${NC}"
    echo -e "${GREEN}   Next: Focus on feature development${NC}"
else
    echo -e "${YELLOW}💡 NEXT STEPS:${NC}"
    echo -e "${YELLOW}   1. Continue cleanup with suggested agents${NC}"
    echo -e "${YELLOW}   2. Run validation: npm run lint && npm run typecheck${NC}"
    echo -e "${YELLOW}   3. Commit clean code when errors are resolved${NC}"
fi

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

exit 0